FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-value

# Leave DATABASE_URL and BACKUP_DIR unset for local development - the app
# computes safe defaults relative to backend/instance/ automatically.
# Only set these when running inside the Docker container, where /app is
# the container's working directory (see docker-compose.yml):
# DATABASE_URL=sqlite:////app/instance/crm.db
# BACKUP_DIR=/app/instance/backups

SESSION_COOKIE_SECURE=false
CORS_ORIGINS=*
PORT=5000
